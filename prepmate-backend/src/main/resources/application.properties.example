spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/prepmate}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:postgres}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:root}
spring.datasource.driver-class-name=org.postgresql.Driver
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

# AI Provider
ai.provider=${AI_PROVIDER:gemini}

# Gemini — set GEMINI_API_KEY env var or paste your key below
gemini.api.key=${GEMINI_API_KEY:YOUR_GEMINI_API_KEY_HERE}
gemini.api.key2=${GEMINI_API_KEY2:}
gemini.api.key3=${GEMINI_API_KEY3:}
gemini.model=${GEMINI_MODEL:gemini-2.5-flash}

jwt.secret=${JWT_SECRET:prepmate-secret-key-change-in-production}
server.port=${PORT:8080}
allowed.origins=${ALLOWED_ORIGINS:http://localhost:5173,http://127.0.0.1:5173}
