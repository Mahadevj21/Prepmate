# Copy to application.properties and fill in values (application.properties is gitignored).

spring.datasource.url=jdbc:postgresql://localhost:5432/prepmate
spring.datasource.username=postgres
spring.datasource.password=CHANGE_ME
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

gemini.api.key=YOUR_GEMINI_API_KEY
gemini.model=gemini-2.0-flash

jwt.secret=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_FOR_HS256

server.port=8080
